rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Sessions collection:
    // - Cloud Function uses Admin SDK so it bypasses these rules to write.
    // - Clients cannot list or write, but can read a session if they have the exact ID.
    match /sessions/{sessionId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
